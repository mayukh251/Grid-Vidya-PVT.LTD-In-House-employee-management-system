generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYEE
  MANAGER
  ADMIN
}

enum TimeEntryType {
  SIGNIN
  SIGNOUT
}

enum TodoStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  TODO
  DONE
}

enum TodoPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TodoOrigin {
  ASSIGNED
  PERSONAL
  CALENDAR
}

enum EodStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                String       @id @default(cuid())
  name              String
  email             String       @unique
  passwordHash      String
  role              Role         @default(EMPLOYEE)
  avatarUrl         String?
  managerId         String?
  manager           User?        @relation("ManagerReports", fields: [managerId], references: [id])
  reports           User[]       @relation("ManagerReports")
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  assignedTodos     Todo[]       @relation("AssignedTo")
  createdTodos      Todo[]       @relation("AssignedBy")
  eodReports        EodReport[]
  approvedEods      EodReport[]  @relation("EodApprover")
  timeEntries       TimeEntry[]
  authoredComments  EodComment[]
  auditLogs         AuditLog[]
  editedMotivations Motivation[] @relation("MotivationEditor")
}

model Todo {
  id            String       @id @default(cuid())
  title         String
  description   String?
  assignedToId  String
  assignedById  String
  dueDate       DateTime?
  status        TodoStatus   @default(PENDING)
  priority      TodoPriority @default(MEDIUM)
  origin        TodoOrigin   @default(ASSIGNED)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  completionAt  DateTime?
  assignee      User         @relation("AssignedTo", fields: [assignedToId], references: [id])
  assigner      User         @relation("AssignedBy", fields: [assignedById], references: [id])

  @@index([assignedToId, dueDate])
  @@index([status])
}

model TimeEntry {
  id        String        @id @default(cuid())
  userId    String
  type      TimeEntryType
  timestamp DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id])

  @@index([userId, timestamp])
}

model EodReport {
  id           String      @id @default(cuid())
  userId       String
  date         DateTime    @db.Date
  tasks        Json
  blockers     String?
  nextPlan     String?
  status       EodStatus   @default(PENDING)
  approvedById String?
  approvedAt   DateTime?
  managerComment String?
  managerRating  Float       @default(3.0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  user         User        @relation(fields: [userId], references: [id])
  approvedBy   User?       @relation("EodApprover", fields: [approvedById], references: [id])
  comments     EodComment[]

  @@unique([userId, date])
  @@index([date, status])
}

model EodComment {
  id        String   @id @default(cuid())
  eodReportId String
  authorId  String
  comment   String
  createdAt DateTime @default(now())
  eodReport EodReport @relation(fields: [eodReportId], references: [id], onDelete: Cascade)
  author    User      @relation(fields: [authorId], references: [id])
}

model Motivation {
  id          String   @id @default(cuid())
  weekday     Int
  text        String
  active      Boolean  @default(true)
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedBy   User?    @relation("MotivationEditor", fields: [updatedById], references: [id])

  @@unique([weekday])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  meta      Json?
  timestamp DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([timestamp])
}


